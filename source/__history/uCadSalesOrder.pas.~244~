  inherited;
   BtnCreateProduct.Enabled := DSCadOrder.State = dsBrowse;
   BtnEditProduct.Enabled   := (DSCadOrder.State = dsBrowse) and (FDMemCadOrder.RecordCount > 0);
   BtnDeleteProduct.Enabled := (DSCadOrder.State = dsBrowse) and (FDMemCadOrder.RecordCount > 0);
   PnlButtons.Enabled       := DSCadOrder.State = dsBrowse;
   DBGridProduto.Enabled    := DSCadOrder.State = dsBrowse;

   BtnSaveProduct.Enabled     := dsCadOrder.State in [dsEdit, dsInsert];
   BtnCancelProduct.Enabled   := dsCadOrder.State in [dsEdit, dsInsert];
   PnlProductsFields.Enabled  := dsCadOrder.State in [dsEdit, dsInsert];
   EdtProductCode.Enabled     := dsCadOrder.State in [dsEdit, dsInsert];
   EdtProductQuantity.Enabled := dsCadOrder.State in [dsEdit, dsInsert];
end;

