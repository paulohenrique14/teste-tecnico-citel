procedure TFrmCadSalesOrder.FormCreate(Sender: TObject);
begin
   FDeletedItems := TList<TOrderItemDeleted>.Create;
   
   FSqlSearchOrder := TFDQuery.Create(Self);

   FDCad.SQL.Text := 'select pg.num_pedido, c.nome, pg.data_emissao, pg.cod_cliente, pg.valor_total '+
                     'from pedidos_geral pg '+
                     'left outer join clientes c on c.cod_cliente = pg.cod_cliente';

   FDCad.Open();
end;

