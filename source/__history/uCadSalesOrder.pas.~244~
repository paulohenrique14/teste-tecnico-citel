procedure TFrmCadSalesOrder.BtnCancelClick(Sender: TObject);
begin
  inherited;
   FDeletedItems.Clear
end;

procedure TFrmCadSalesOrder.BtnCopyClick(Sender: TObject);
var
   mOldClientName: String;
   mOldClientCode: Integer;
begin
   LoadOrder(FDCadnum_pedido.AsInteger);

   mOldClientName := FDCad.FieldByName('nome').AsString;
   mOldClientCode := FDCad.FieldByName('cod_cliente').AsInteger;

   FDCad.Append;

   FDCad.FieldByName('nome').AsString         := mOldClientName;
   FDCad.FieldByName('cod_cliente').AsInteger := mOldClientCode;

   FDMemCadOrder.First;
   while not FDMemCadOrder.Eof do
   begin
      FDMemCadOrder.Edit;
      FDMemCadOrder.FieldByName('id').AsInteger := 0;
      FDMemCadOrder.FieldByName('num_pedido').AsInteger := 0;
      FDMemCadOrder.Post;
      FDMemCadOrder.Next;
   end;

   DBGridProduto.SetFocus;
end;

procedure TFrmCadSalesOrder.BtnCreateClick(Sender: TObject);
begin
  inherited;

   if not FDMemCadOrder.Active then
      FDMemCadOrder.Open;

   FDMemCadOrder.EmptyDataSet;
   EdtProductCode.Clear;
   EdtProductName.Clear;
   EdtProductQuantity.Clear;
   EdtProductPrice.Clear;

   DBEdtClientCode.SetFocus;
end;

procedure TFrmCadSalesOrder.BtnCreateProductClick(Sender: TObject);
begin
   FDMemCadOrder.Append;
   EdtProductCode.Clear;
   EdtProductCode.SetFocus;

end;

procedure TFrmCadSalesOrder.BtnDeleteClick(Sender: TObject);
var
   mDeleteProductOrder: ICrud;
   mTransaction: TFDTransaction;
begin
   if MessageDlg('Tem certeza que deseja apagar o pedido?',mtConfirmation,[mbYes,mbNo],0) = mrYes then
   begin
      mTransaction := TFDTransaction.Create(Self);
      mDeleteProductOrder := TCrudSalesOrderProduct.New;

      try
         mTransaction.Connection := FrmDm.FDMainConnection;

         FDCad.Transaction := mTransaction;

         mTransaction.StartTransaction;

         try
            mDeleteProductOrder.Delete(FDMemCadOrder, mTransaction, FDCadnum_pedido.AsInteger);

            FDCad.Delete;
            FDCad.ApplyUpdates(0);

            mTransaction.Commit;
         except on E: Exception do
            begin
               mTransaction.Rollback;
               FDCad.Cancel;
               MessageDlg('Erro ao deletar o pedido: ' + E.Message, mtError, [mbOK], 0);
            end;
         end;


      finally
         mTransaction.Free;
      end;
   end;
end;

procedure TFrmCadSalesOrder.BtnDeleteProductClick(Sender: TObject);
var
   mItem: TOrderItemDeleted;
begin
   if MessageDlg('Deseja excluir este produto?', mtConfirmation, [mbYes, mbNo], 0) <> mrYes then
      Exit;

   if FDMemCadOrderid.AsInteger > 0 then
   begin
      mItem.IdItem    := FDMemCadOrderid.AsInteger;
      mItem.NumPedido := FDMemCadOrdernum_pedidos.AsInteger;
      FDeletedItems.Add(mItem);
   end;

  FDMemCadOrder.Delete;
  UpdateAggregateFields
end;

