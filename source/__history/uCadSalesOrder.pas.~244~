procedure TFrmCadSalesOrder.FDMemCadOrderCalcFields(DataSet: TDataSet);
begin
   if FDMemCadOrder.FieldByName('quantidade' ).IsNull or
      FDMemCadOrder.FieldByName('vr_unitario').IsNull then
   begin
      FDMemCadOrder.FieldByName('vr_total').AsCurrency := 0;
      Exit;
   end;

   FDMemCadOrder.FieldByName('vr_total').AsCurrency := FDMemCadOrder.FieldByName('quantidade' ).AsFloat * FDMemCadOrder.FieldByName('vr_unitario').AsCurrency;
end;

procedure TFrmCadSalesOrder.FillProductsData;
begin
  if not FDMemCadOrder.Active then Exit;

   if FDMemCadOrder.RecordCount > 0 then
   begin
      EdtProductCode.Text     := FDMemCadOrder.FieldByName('cod_produto').AsString;
      EdtProductName.Text     := FDMemCadOrder.FieldByName('descricao').AsString;
      EdtProductQuantity.Text := FDMemCadOrder.FieldByName('quantidade').AsString;
      EdtProductPrice.Text    := FDMemCadOrder.FieldByName('vr_unitario').AsString;
   end;

   UpdateAggregateFields;
end;

