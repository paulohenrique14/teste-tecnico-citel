procedure TFrmCadSalesOrder.BtnSaveClick(Sender: TObject);
var
   mTransaction: TFDTransaction;
   mSaveProductOrder: ICrud;
   mTotal: Variant;
begin
   if FDCadcod_cliente.AsInteger = 0 then
   begin
      MessageDlg('Favor informar um cliente para o pedido de venda.',mtInformation,[mbOK],0);
      DBEdtClientCode.SetFocus;
      Exit;
   end;

   if FDMemCadOrder.RecordCount = 0 then
   begin
      if MessageDlg('Deseja salvar o pedido sem itens vinculados?',mtConfirmation,[mbYes, mbNo],0) = mrNo then
      begin
         EdtProductCode.SetFocus;
         Exit;
      end;
   end;

   mTransaction := TFDTransaction.Create(Self);
   mSaveProductOrder := TCrudSalesOrderProduct.New;
   try
      mTransaction.Connection := FrmDm.FDMainConnection;

      FDCad.Transaction := mTransaction;

      mTransaction.StartTransaction;

      try
         mTotal := FDMemCadOrder.FieldByName('vr_total_agg').Value;

         if not (VarIsNull(mTotal) or VarIsEmpty(mTotal)) then
            FDCadvalor_total.AsCurrency := mTotal
         else
            FDCadvalor_total.AsCurrency := 0;

         FDCaddata_emissao.AsDateTime := Date;

         FDCad.Post;
         FDCad.ApplyUpdates(0);

         mSaveProductOrder.UpdateOrInsert(FDMemCadOrder, mTransaction, FDCadnum_pedido.AsInteger);
         mSaveProductOrder.DeleteItemById(FDeletedItems, mTransaction);

         mTransaction.Commit;

      except on E: Exception do
         begin
            mTransaction.Rollback;
            FDCad.Cancel;
            MessageDlg('Erro ao salvar pedido: ' + E.Message, mtError, [mbOK], 0);
         end;
      end;
   finally
      mTransaction.Free;
      FDeletedItems.Clear;
   end;
end;

procedure TFrmCadSalesOrder.BtnSaveProductClick(Sender: TObject);
begin
   if Trim(EdtProductCode.Text) = '' then
   begin
      MessageDlg('Favor informar um produto.',mtInformation,[mbOK],0);
      EdtProductCode.SetFocus;
      Exit;
   end;

   if (Trim(EdtProductQuantity.Text) = '') or (StrToIntDef(EdtProductQuantity.Text, 0) <= 0) then
   begin
      MessageDlg('Favor a quantidade do produto.',mtInformation,[mbOK],0);
      EdtProductQuantity.SetFocus;
      Exit;
   end;

   DSCadOrder.OnDataChange := nil;
   try
      FDMemCadOrder.FieldByName('cod_produto' ).AsInteger  := StrToInt(EdtProductCode.Text);
      FDMemCadOrder.FieldByName('descricao'   ).AsString   := Trim(EdtProductName.Text);
      FDMemCadOrder.FieldByName('vr_unitario' ).AsCurrency := StrToCurrDef(EdtProductPrice.Text, 0);
      FDMemCadOrder.FieldByName('quantidade'  ).AsCurrency := StrToCurrDef(EdtProductQuantity.Text, 0);
      FDMemCadOrder.Post;
      DBGridProduto.Refresh;
   finally
      DSCadOrder.OnDataChange := DSCadOrderDataChange;
      UpdateAggregateFields
   end;
end;

procedure TFrmCadSalesOrder.BtnSearchClientClick(Sender: TObject);
begin
   FrmLookup := TFrmLookup.Create('clientes', 'cod_cliente', 'nome');
   try
      if FrmLookup.ShowModal = mrOk then
      begin
         FDCadcod_cliente.AsInteger := FrmLookup.FSelectedCode;
         LocateClient
      end;
   finally
      FrmLookup.Free;
   end;
end;

procedure TFrmCadSalesOrder.BtnSearchProductClick(Sender: TObject);
begin
   FrmLookup := TFrmLookup.Create('produtos', 'cod_produto', 'descricao');
   try
      if FrmLookup.ShowModal = mrOk then
      begin
         LocateProduct
      end;
   finally
      FrmLookup.Free;
   end;
end;

procedure TFrmCadSalesOrder.DBEdtClientCodeEnter(Sender: TObject);
begin
  inherited;
   FOldClientValue := FDCadcod_cliente.AsInteger;
end;

procedure TFrmCadSalesOrder.DBEdtClientCodeExit(Sender: TObject);
var
   FDSearch: TFDQuery;
begin
   FDSearch := TFDQuery.Create(Self);
   try
      if FDCadcod_cliente.AsInteger <> FOldClientValue then
      begin
         if TSqlUtils.Locate('clientes', FDSearch, FDCadcod_cliente.AsInteger, 'cod_cliente', ['nome']) then
            LocateClient
         else
         begin
            FrmLookup := TFrmLookup.Create('clientes', 'cod_cliente', 'nome');

            try
               if FrmLookup.ShowModal = mrOk then
               begin
                  FDCadcod_cliente.AsInteger := FrmLookup.FSelectedCode;

                  if TSqlUtils.Locate('clientes', FDSearch, FDCadcod_cliente.AsInteger, 'cod_cliente', ['nome']) then
                  begin
                     FDCadnome.AsString := FDSearch.FieldByName('nome').AsString;

                  end
               end;
            finally
               FrmLookup.Free;
            end;
         end;
      end;
   finally
      FDSearch.Free;
   end;
end;

procedure TFrmCadSalesOrder.DBGridKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
   if DSCad.State <> dsBrowse then Exit;

   case Key of
      13:
      begin
         if FDCad.RecordCount > 0 then
         begin
            BtnEdit.Click;
            Key := 0;
         end;
      end;

      46:
      begin
         if FDCad.RecordCount > 0 then
         begin
            BtnDelete.Click;
            Key := 0;
         end;
      end;
   end;
end;

procedure TFrmCadSalesOrder.DBGridProdutoKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
   if DSCadOrder.State <> dsBrowse then Exit;

   case Key of
      13:
      begin
         if FDMemCadOrder.RecordCount > 0 then
         begin
            BtnEditProduct.Click;
            Key := 0;
         end;
      end;

      46:
      begin
         if FDMemCadOrder.RecordCount > 0 then
         begin
            BtnDeleteProduct.Click;
            Key := 0;
         end;
      end;
   end;
end;

