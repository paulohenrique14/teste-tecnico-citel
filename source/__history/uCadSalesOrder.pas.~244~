procedure TFrmCadSalesOrder.LoadOrder(AOrderCode: Integer);
begin

   FSqlSearchOrder.Connection := FrmDm.FDMainConnection;

   FSqlSearchOrder.Close;

   FSqlSearchOrder.SQL.Text := 'Select pp.id, pp.num_pedido, CAST(pp.quantidade AS DECIMAL(10,3)) as quantidade, '+
                              '       pp.vr_unitario, pp.vr_total, p.cod_produto, p.descricao '+
                              'from pedidos_produtos pp '+
                              'left outer join produtos p on p.cod_produto = pp.cod_produto '+
                              'where num_pedido = :num_pedido';

   FSqlSearchOrder.ParamByName('num_pedido').AsInteger := AOrderCode;

   FSqlSearchOrder.Open();

   if not FDMemCadOrder.Active then
      FDMemCadOrder.Open;

   FDMemCadOrder.EmptyDataSet;

   FDMemCadOrder.CopyDataSet(FSqlSearchOrder, [coRestart, coAppend]);

   FDMemCadOrder.AggregatesActive := True;

   DSCadOrder.OnStateChange(DSCadOrder);

end;

procedure TFrmCadSalesOrder.LocateClient;
var
   FDSearch: TFDQuery;
begin
   FDSearch := TFDQuery.Create(Self);
   try
      if TSqlUtils.Locate('clientes', FDSearch, FDCadcod_cliente.AsInteger, 'cod_cliente', ['nome']) then
      begin
         FDCadnome.AsString := FDSearch.FieldByName('nome').AsString;
      end
   finally
      FDSearch.Free;
   end;
end;

procedure TFrmCadSalesOrder.LocateProduct;
var
   FDSearch: TFDQuery;
begin
   FDSearch := TFDQuery.Create(Self);
   try
      if TSqlUtils.Locate('produtos', FDSearch, StrToInt(EdtProductCode.Text), 'cod_produto', ['cod_produto, descricao, preco_venda']) then
      begin
         EdtProductCode.Text := FrmLookup.FSelectedCode.ToString;
         EdtProductName.Text := FDSearch.FieldByName('descricao').AsString;
         EdtProductPrice.Text := FloatToStr(FDSearch.FieldByName('preco_venda').AsFloat);
      end
   finally
      FDSearch.Free;
   end;
end;

procedure TFrmCadSalesOrder.UpdateAggregateFields;
var
  mQuantityAgg: Variant;
  mVrTotalAgg: Variant;
begin
   mQuantityAgg := FDMemCadOrder.FieldByName('quantidade_agg').Value;
   mVrTotalAgg  := FDMemCadOrder.FieldByName('vr_total_agg').Value;

   if not (VarIsNull(mQuantityAgg) or VarIsEmpty(mQuantityAgg)) then
      LblTotalValue.Caption := 'Qtde: ' + FormatFloat('#,##0.000', mQuantityAgg);

   if not (VarIsNull(mVrTotalAgg) or VarIsEmpty(mVrTotalAgg)) then
      LblTotalQuantity.Caption := 'Total: R$ ' + FormatCurr('#,##0.00', mVrTotalAgg);
end;

end.
