   if (PnlProductButtons.Enabled) and (PnlProductButtons.Visible) then
   begin

      if (Msg.CharCode = VK_F3) then
      begin
         if ((BtnCreateProduct.Visible) and (BtnCreateProduct.Enabled) and (DSCadOrder.State in [dsBrowse]) and (CardPanel.ActiveCard = CardCreate)) then
         begin
            BtnCreateProduct.SetFocus;
            BtnCreateProduct.Click;
            Exit;
         end;
      end;

      if (Msg.CharCode = VK_F4) and (CardPanel.ActiveCard = CardCreate) then
      begin
         if ((BtnEditProduct.Visible) and (BtnEditProduct.Enabled) and (DSCadOrder.State in [dsBrowse])) then
         begin
            BtnEditProduct.SetFocus;
            BtnEditProduct.Click;
            Exit;
         end;
      end;

      if (Msg.CharCode = VK_F5) and (CardPanel.ActiveCard = CardCreate) then
      begin
         if ((BtnSaveProduct.Visible) and (BtnSaveProduct.Enabled)) then
         begin
            BtnSaveProduct.SetFocus;
            BtnSaveProduct.Click;
            Exit;
         end;
      end;

      if (Msg.CharCode = VK_F6) and (CardPanel.ActiveCard = CardCreate) then
      begin
         if ((BtnDeleteProduct.Visible) and (BtnDeleteProduct.Enabled)) then
         begin
            BtnDeleteProduct.SetFocus;
            BtnDeleteProduct.Click;
            Exit;
         end;
      end;

      if (Msg.CharCode = VK_F7) then
      begin
         if ((BtnCopy.Visible) and (BtnCopy.Enabled)) then
         begin
            BtnCopy.SetFocus;
            BtnCopy.Click;
            Exit;
         end;
      end;
   end;

   inherited;
end;

