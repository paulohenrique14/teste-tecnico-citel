   FOldProductValue := FDMemCadOrdercod_produto.AsInteger;
end;

procedure TFrmCadSalesOrder.EdtProductCodeExit(Sender: TObject);
var
   FDSearch : TFDQuery;
begin
   FDSearch := TFDQuery.Create(Self);
   try
      if StrToIntDef(EdtProductCode.Text, 0) <> FOldProductValue then
      begin
         if TSqlUtils.Locate('produtos', FDSearch, StrToIntDef(EdtProductCode.Text, 0), 'cod_produto', ['descricao', 'preco_venda']) then
         begin
            EdtProductName.Text := FDSearch.FieldByName('descricao').AsString;
            EdtProductPrice.Text := CurrToStr(FDSearch.FieldByName('preco_venda').AsCurrency);
         end
         else
         begin
      //      EdtClientName.Text := '';
      //      ShowMessage('Cliente n緌 encontrado.');
      //      EdtClientCode.SetFocus;
         end;
      end;
   finally
      FDSearch.Free;
   end;

