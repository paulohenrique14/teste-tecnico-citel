procedure TFrmMain.CriaBancoDados;
var
  FSqlScript: TFDQuery;
begin
  if MessageDlg('Deseja recriar o banco de dados? Todos os dados serăo perdidos!', mtConfirmation, [mbYes, mbNo], 0) = mrNo then Exit;

  FSqlScript := TFDQuery.Create(Self);
  try
    FSqlScript.Connection := FrmDm.FDMainConnection;

    // desconecta do banco atual para poder dropar
    FrmDm.FDMainConnection.Connected := False;

    // reconecta sem especificar banco para executar o DROP/CREATE
    FrmDm.FDMainConnection.Params.Values['Database'] := '';
    FrmDm.FDMainConnection.Connected := True;

    FSqlScript.SQL.Text := 'DROP DATABASE IF EXISTS db_pedidos';
    FSqlScript.ExecSQL;

    FSqlScript.SQL.Text := 'CREATE DATABASE db_pedidos CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci';
    FSqlScript.ExecSQL;

    FSqlScript.SQL.Text := 'USE db_pedidos';
    FSqlScript.ExecSQL;

    // reconecta apontando para o banco novo
    FrmDm.FDMainConnection.Connected := False;
    FrmDm.FDMainConnection.Params.Values['Database'] := 'db_pedidos';
    FrmDm.FDMainConnection.Connected := True;

    FSqlScript.SQL.Text := 'SET FOREIGN_KEY_CHECKS = 0';
    FSqlScript.ExecSQL;

    // clientes
    FSqlScript.SQL.Text := 'CREATE TABLE clientes ( ' +
                           '  cod_cliente  INT          NOT NULL AUTO_INCREMENT,' +
                           '  nome         VARCHAR(100) NOT NULL, ' +
                           '  cidade       VARCHAR(80)  NOT NULL, ' +
                           '  uf           CHAR(2)      NOT NULL, ' +
                           '  CONSTRAINT pk_clientes PRIMARY KEY (cod_cliente), ' +
                           '  INDEX idx_clientes_nome (nome), ' +
                           '  INDEX idx_clientes_uf   (uf) ' +
                           ') ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 ';
    FSqlScript.ExecSQL;

    // produtos
    FSqlScript.SQL.Text := 'CREATE TABLE produtos ( ' +
                           '  cod_produto  INT            NOT NULL AUTO_INCREMENT,' +
                           '  descricao    VARCHAR(150)   NOT NULL, ' +
                           '  preco_venda  DECIMAL(10, 2) NOT NULL, ' +
                           '  CONSTRAINT pk_produtos PRIMARY KEY (cod_produto), ' +
                           '  INDEX idx_produtos_descricao (descricao) ' +
                           ') ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 ';
    FSqlScript.ExecSQL;

    // pedidos_geral
    FSqlScript.SQL.Text := 'CREATE TABLE pedidos_geral ( ' +
                           '  num_pedido   INT            NOT NULL AUTO_INCREMENT, ' +
                           '  data_emissao DATE           NOT NULL, ' +
                           '  cod_cliente  INT            NOT NULL, ' +
                           '  valor_total  DECIMAL(10, 2) NOT NULL DEFAULT 0.00, ' +
                           '  CONSTRAINT pk_pedidos_geral    PRIMARY KEY (num_pedido), ' +
                           '  CONSTRAINT fk_pedgeral_cliente FOREIGN KEY (cod_cliente) ' +
                           '    REFERENCES clientes (cod_cliente) ' +
                           '    ON UPDATE CASCADE ON DELETE RESTRICT, ' +
                           '  INDEX idx_pedgeral_cliente (cod_cliente), ' +
                           '  INDEX idx_pedgeral_data    (data_emissao) ' +
                           ') ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 ';
    FSqlScript.ExecSQL;

    // pedidos_produtos
    FSqlScript.SQL.Text := 'CREATE TABLE pedidos_produtos ( ' +
                           '  id           INT            NOT NULL AUTO_INCREMENT, ' +
                           '  num_pedido   INT            NOT NULL, ' +
                           '  cod_produto  INT            NOT NULL, ' +
                           '  quantidade   DECIMAL(10, 3) NOT NULL, ' +
                           '  vr_unitario  DECIMAL(10, 2) NOT NULL, ' +
                           '  vr_total     DECIMAL(10, 2) NOT NULL, ' +
                           '  CONSTRAINT pk_pedidos_produtos PRIMARY KEY (id), ' +
                           '  CONSTRAINT fk_pedprod_pedido   FOREIGN KEY (num_pedido) ' +
                           '    REFERENCES pedidos_geral (num_pedido) ' +
                           '    ON UPDATE CASCADE ON DELETE CASCADE, ' +
                           '  CONSTRAINT fk_pedprod_produto  FOREIGN KEY (cod_produto) ' +
                           '    REFERENCES produtos (cod_produto) ' +
                           '    ON UPDATE CASCADE ON DELETE RESTRICT, ' +
                           '  INDEX idx_pedprod_pedido  (num_pedido), ' +
                           '  INDEX idx_pedprod_produto (cod_produto) ' +
                           ') ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 ';
    FSqlScript.ExecSQL;

    FSqlScript.SQL.Text := 'SET FOREIGN_KEY_CHECKS = 1';
    FSqlScript.ExecSQL;

    ShowMessage('Banco recriado com sucesso! Execute agora a carga de dados padrăo.');

  except
    on E: Exception do
    begin
      // tenta reconectar ao banco em caso de erro
      try
        FrmDm.FDMainConnection.Connected := False;
        FrmDm.FDMainConnection.Params.Values['Database'] := 'db_pedidos';
        FrmDm.FDMainConnection.Connected := True;
      except
      end;
      ShowMessage('Erro ao recriar banco: ' + E.Message);
    end;
  end;

  FSqlScript.Free;
end;

